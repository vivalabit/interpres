{
  "manifest_version": 3,
  "name": "Selection Translator MVP",
  "version": "0.1.0",
  "description": "Translates selected text and shows a compact explanation popup near the selection.",
  "permissions": ["storage", "contextMenus", "scripting", "activeTab"],
  "host_permissions": [
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Selection Translator MVP"
  }
}
